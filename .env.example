# Backend API URL (set to your AWS backend URL in production)
NEXT_PUBLIC_API_URL=https://your-backend-domain.com/api

# Razorpay (public key only)
NEXT_PUBLIC_RAZORPAY_KEY_ID=your_razorpay_key_id

# Firebase Configuration (for phone auth & Google sign-in)
# Get these from: https://console.firebase.google.com/project/project-843249196918/settings/general
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=project-843249196918.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=project-843249196918
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=project-843249196918.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
